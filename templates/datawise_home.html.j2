<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ company_name | default('Data WiseGuys, LLC') }}</title>
</head>
<body>
  <header>
    <h1>{{ company_name | default('Data WiseGuys, LLC') }}</h1>
    <p>{{ company_tagline | default('Turning data into clear, actionable outcomes.') }}</p>
    <p>
      Contact:
      <a href="mailto:{{ company_email | default('datawiseguysllc@gmail.com') }}">
        {{ company_email | default('datawiseguysllc@gmail.com') }}
      </a>
    </p>

    <nav aria-label="Social media">
      <ul>
        {% set social_links = social_links | default({
          'x': '#',
          'facebook': '#',
          'instagram': '#',
          'tiktok': '#'
        }) %}
        <li><a href="{{ social_links.x }}" target="_blank" rel="noopener noreferrer">X</a></li>
        <li><a href="{{ social_links.facebook }}" target="_blank" rel="noopener noreferrer">Facebook</a></li>
        <li><a href="{{ social_links.instagram }}" target="_blank" rel="noopener noreferrer">Instagram</a></li>
        <li><a href="{{ social_links.tiktok }}" target="_blank" rel="noopener noreferrer">TikTok</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section id="projects" aria-labelledby="projects-title">
      <h2 id="projects-title">Projects</h2>
      {% set projects = projects | default([
        {
          'name': 'SocialSync',
          'logo_url': 'docs/socialsync_logo.png',
          'logo_alt': 'SocialSync logo',
          'contact_email': 'socialsyncdwg@gmail.com',
          'description': 'Placeholder description for SocialSync.',
          'site_url': '#',
          'social_handles': {
            'x': 'https://x.com/socialsyncdwg',
            'facebook': 'https://www.facebook.com/profile.php?id=61586199493081',
            'instagram': 'https://www.instagram.com/socialsyncdwg/',
            'tiktok': 'https://www.tiktok.com/@rolandheinze3?_r=1&_t=ZT-94lRhOOmUYP',
            'discord': 'https://discord.gg/WUGqSXsryD'
          }
        },
        {
          'name': 'ProspectRecon',
          'logo_url': 'docs/prospectrecon_logo_20260317.png',
          'logo_alt': 'ProspectRecon logo',
          'contact_email': '',
          'description': 'Placeholder description for ProspectRecon.',
          'site_url': '#',
          'social_handles': {
            'x': '#',
            'facebook': '#',
            'instagram': '#',
            'tiktok': '#'
          }
        },
        {
          'name': 'StashSage',
          'logo_url': 'docs/stashsage_logo.png',
          'logo_alt': 'StashSage logo',
          'contact_email': 'datawiseguysllc@gmail.com',
          'description': 'Placeholder description for StashSage.',
          'site_url': '#',
          'social_handles': {
            'x': 'https://x.com/rheinze08',
            'facebook': 'https://www.facebook.com/profile.php?id=61582292837909',
            'instagram': 'https://www.instagram.com/heinze_roland/',
            'tiktok': '#',
            'discord': 'https://discord.gg/k58TnRgFPb'
          }
        },
        {
          'name': 'Insight Connect',
          'logo_url': 'docs/insight_connect_logo_20260310.png',
          'logo_alt': 'Insight Connect logo',
          'contact_email': '',
          'description': 'Placeholder description for Insight Connect.',
          'site_url': '#',
          'social_handles': {
            'x': '#',
            'facebook': '#',
            'instagram': '#',
            'tiktok': '#'
          }
        }
      ]) %}

      <div class="project-grid">
        {% for project in projects %}
          <article class="project-card">
            <img src="{{ project.logo_url }}" alt="{{ project.logo_alt }}" width="160" height="160">
            <h3>{{ project.name }}</h3>
            <p>{{ project.description }}</p>
            {% if project.contact_email %}
            <p>
              Contact:
              <a href="mailto:{{ project.contact_email }}">{{ project.contact_email }}</a>
            </p>
            {% endif %}
            <p><a href="{{ project.site_url }}" target="_blank" rel="noopener noreferrer">Visit {{ project.name }}</a></p>
            {% set project_social_handles = project.social_handles | default({
              'x': '#',
              'facebook': '#',
              'instagram': '#',
              'tiktok': '#'
            }) %}
            <p>
              Follow {{ project.name }}:
              <a href="{{ project_social_handles.x }}" target="_blank" rel="noopener noreferrer">X</a>,
              <a href="{{ project_social_handles.facebook }}" target="_blank" rel="noopener noreferrer">Facebook</a>,
              <a href="{{ project_social_handles.instagram }}" target="_blank" rel="noopener noreferrer">Instagram</a>,
              <a href="{{ project_social_handles.tiktok }}" target="_blank" rel="noopener noreferrer">TikTok</a>{% if project_social_handles.discord and project_social_handles.discord != '#' %},
              <a href="{{ project_social_handles.discord }}" target="_blank" rel="noopener noreferrer">Discord</a>{% endif %}
            </p>
          </article>
        {% endfor %}
      </div>
    </section>

    <section id="team" aria-labelledby="team-title">
      <h2 id="team-title">Meet the Team</h2>
      {% set team_members = team_members | default([
        {
          'name': 'Roland Heinze',
          'image_url': 'docs/roland_heinze_portrait_20260317.png',
          'image_alt': 'Portrait of Roland Heinze',
          'position': 'Founder, CEO',
          'description': 'Founder and CEO of Data WiseGuys, LLC.',
          'minnect_url': '',
          'linkedin_url': 'https://www.linkedin.com/me?trk=p_mwlite_feed-secondary_nav'
        }
      ]) %}

      <div class="team-grid">
        {% for member in team_members %}
          <article class="team-card">
            <img src="{{ member.image_url }}" alt="{{ member.image_alt }}" width="180" height="180">
            <h3>{{ member.name }}</h3>
            <p><strong>{{ member.position }}</strong></p>
            <p>{{ member.description }}</p>
            {% if member.minnect_url or member.linkedin_url %}
            <p>
              {% if member.minnect_url %}
              <a href="{{ member.minnect_url }}" target="_blank" rel="noopener noreferrer">Minnect Profile</a>
              {% endif %}
              {% if member.minnect_url and member.linkedin_url %}|{% endif %}
              {% if member.linkedin_url %}
              <a href="{{ member.linkedin_url }}" target="_blank" rel="noopener noreferrer">LinkedIn Profile</a>
              {% endif %}
            </p>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </section>
  </main>
</body>
</html>
